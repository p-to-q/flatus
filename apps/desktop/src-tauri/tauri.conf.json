{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flatus",
  "version": "0.2.1",
  "identifier": "io.ptoq.flatus",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "flatus",
        "width": 760,
        "height": 720,
        "minWidth": 560,
        "minHeight": 600,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns", "icons/icon.png", "icons/icon.ico"],
    "category": "Utility",
    "shortDescription": "A small apparatus for moving air.",
    "longDescription": "flatus — a desktop companion that vibrates a laptop speaker near its resonance, in the manner of a fart.",
    "resources": ["../resources/*"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "providerShortName": null,
      "exceptionDomain": null,
      "dmg": {
        "background": "../resources/dmg-background.tiff",
        "windowSize": { "width": 540, "height": 380 },
        "appPosition": { "x": 150, "y": 220 },
        "applicationFolderPosition": { "x": 390, "y": 220 }
      }
    }
  }
}
